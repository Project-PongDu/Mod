<?xml version="1.0" encoding="utf-8"?>
<!-- 트레이서 낮은담장 볼트 후반부 (Vaulting Zombies end.xml 기반, Sprint 교체).
     outcome은 Lua(updateTracer)가 매 틱 success로 강제하므로 사실상 항상 이 노드. -->
<animNode>
	<m_Name>TRclimbFenceEnd</m_Name>
	<m_AnimName>Bob_ValultOver_Sprint</m_AnimName>
	<m_Priority>5</m_Priority>
	<m_deferredBoneAxis>Y</m_deferredBoneAxis>
	<m_Looped>false</m_Looped>
	<m_SpeedScale>0.80</m_SpeedScale>
	<m_BlendTime>0.20</m_BlendTime>
	<m_Conditions>
		<m_Name>PuppetTracer</m_Name>
		<m_Type>BOOL</m_Type>
		<m_BoolValue>true</m_BoolValue>
	</m_Conditions>
	<m_Conditions>
		<m_Name>ClimbFenceStarted</m_Name>
		<m_Type>BOOL</m_Type>
		<m_BoolValue>true</m_BoolValue>
	</m_Conditions>
	<m_Conditions>
		<m_Name>ClimbFenceOutcome</m_Name>
		<m_Type>STRING</m_Type>
		<m_StringValue>success</m_StringValue>
	</m_Conditions>
	<m_Events>
		<m_EventName>SetVariable</m_EventName>
		<m_Time>End</m_Time>
		<m_ParameterValue>ClimbFenceFinished=true</m_ParameterValue>
	</m_Events>
</animNode>
