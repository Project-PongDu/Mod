<?xml version="1.0" encoding="utf-8"?>
<!-- 트레이서 창문 볼트 후반부 (Vaulting Zombies climbwindow/end.xml 기반, Sprint 교체).
     BlockWindow=false를 0.1 시점에 풀어 후속 좀비의 창문 진입을 재허용. -->
<animNode>
	<m_Name>TRclimbWindowEnd</m_Name>
	<m_AnimName>Bob_ValultOver_Sprint</m_AnimName>
	<m_Priority>5</m_Priority>
	<m_deferredBoneAxis>Y</m_deferredBoneAxis>
	<m_Looped>false</m_Looped>
	<m_SpeedScale>0.80</m_SpeedScale>
	<m_BlendTime>0.40</m_BlendTime>
	<m_Conditions>
		<m_Name>PuppetTracer</m_Name>
		<m_Type>BOOL</m_Type>
		<m_BoolValue>true</m_BoolValue>
	</m_Conditions>
	<m_Conditions>
		<m_Name>ClimbWindowStarted</m_Name>
		<m_Type>BOOL</m_Type>
		<m_BoolValue>true</m_BoolValue>
	</m_Conditions>
	<m_Conditions>
		<m_Name>ClimbWindowOutcome</m_Name>
		<m_Type>STRING</m_Type>
		<m_StringValue>success</m_StringValue>
	</m_Conditions>
	<m_Events>
		<m_EventName>SetVariable</m_EventName>
		<m_Time>End</m_Time>
		<m_ParameterValue>ClimbWindowFinished=true</m_ParameterValue>
	</m_Events>
	<m_Events>
		<m_EventName>SetVariable</m_EventName>
		<m_TimePc>0.1</m_TimePc>
		<m_ParameterValue>BlockWindow=false</m_ParameterValue>
	</m_Events>
</animNode>
