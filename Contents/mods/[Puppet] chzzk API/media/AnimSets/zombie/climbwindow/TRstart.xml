<?xml version="1.0" encoding="utf-8"?>
<!-- 트레이서가 열린/이미 깨진 창문을 AI 경로로 통과할 때(ClimbThroughWindowState)의
     전반부. Vaulting Zombies climbwindow/start.xml 구조(BlockWindow 이벤트 포함)에
     애님만 Sprint 볼트로 교체. 닫힌 창문은 이 스테이트를 타지 않고
     OnObjectCollide -> 즉시파괴 -> climbOverFence(DTW 패턴) 경로로 처리된다. -->
<animNode>
	<m_Name>TRclimbWindowStart</m_Name>
	<m_AnimName>Bob_ValultOver_Sprint</m_AnimName>
	<m_Priority>5</m_Priority>
	<m_deferredBoneAxis>Y</m_deferredBoneAxis>
	<m_Looped>false</m_Looped>
	<m_EarlyTransitionOut>true</m_EarlyTransitionOut>
	<m_SpeedScale>0.80</m_SpeedScale>
	<m_BlendTime>0.20</m_BlendTime>
	<m_Conditions>
		<m_Name>PuppetTracer</m_Name>
		<m_Type>BOOL</m_Type>
		<m_BoolValue>true</m_BoolValue>
	</m_Conditions>
	<m_Conditions>
		<m_Name>ClimbWindowStarted</m_Name>
		<m_Type>BOOL</m_Type>
		<m_BoolValue>false</m_BoolValue>
	</m_Conditions>
	<m_Events>
		<m_EventName>SetVariable</m_EventName>
		<m_Time>End</m_Time>
		<m_ParameterValue>ClimbWindowStarted=true</m_ParameterValue>
	</m_Events>
	<m_Events>
		<m_EventName>SetVariable</m_EventName>
		<m_TimePc>0.5</m_TimePc>
		<m_ParameterValue>BlockWindow=true</m_ParameterValue>
	</m_Events>
	<m_Events>
		<m_EventName>PlayWindowSound</m_EventName>
		<m_Time>Start</m_Time>
		<m_ParameterValue>ClimbThroughWindow</m_ParameterValue>
	</m_Events>
</animNode>
