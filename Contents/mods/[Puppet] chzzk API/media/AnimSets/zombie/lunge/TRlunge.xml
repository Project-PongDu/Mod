<?xml version="1.0" encoding="utf-8"?>
<!-- 트레이서 이속 오버라이드: 바닐라 lunge/sprintN.xml (5종 전부 Zombie_Sprint06 동일 - 단일노드로 통합) 사본에 PuppetTracer 조건 + Priority를
     얹고 m_SpeedScale을 숫자 대신 변수명으로 교체. 엔진(AnimNode.getSpeedScale)이
     숫자 파싱 실패 시 getVariableFloat("TracerLungeSpeed", 1.0)로 읽는 것을 이용 -
     Lua(updateTracer)가 매 틱 세팅하는 TracerLungeSpeed 값이 곧 재생배속=루트모션 이속.
     바닐라 기준값 0.90 x 1.2 = Lua에서 1.08 세팅. -->
<animNode>
	<m_Name>TRlunge</m_Name>
	<m_AnimName>Zombie_Sprint06</m_AnimName>
	<m_Priority>5</m_Priority>
	<m_deferredBoneAxis>Y</m_deferredBoneAxis>
	<m_SpeedScale>TracerLungeSpeed</m_SpeedScale>
	<m_BlendTime>0.35</m_BlendTime>
	<m_Conditions>
		<m_Name>intrees</m_Name>
		<m_Type>BOOL</m_Type>
		<m_BoolValue>false</m_BoolValue>
	</m_Conditions>
	<m_Conditions>
		<m_Name>PuppetTracer</m_Name>
		<m_Type>BOOL</m_Type>
		<m_BoolValue>true</m_BoolValue>
	</m_Conditions>
	<m_Events>
		<m_EventName>Footstep</m_EventName>
		<m_TimePc>0.15</m_TimePc>
		<m_ParameterValue>sprint</m_ParameterValue>
	</m_Events>
	<m_Events>
		<m_EventName>Footstep</m_EventName>
		<m_TimePc>0.6</m_TimePc>
		<m_ParameterValue>sprint</m_ParameterValue>
	</m_Events>
</animNode>
