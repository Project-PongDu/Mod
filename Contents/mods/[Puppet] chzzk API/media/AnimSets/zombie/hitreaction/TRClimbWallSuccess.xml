<?xml version="1.0" encoding="utf-8"?>
<!-- 트레이서 높은담장 클라임 성공부 (ZombieClimbWallSuccess.xml 포팅, TR 네임스페이스).
     트레이서는 100% 성공이므로 Fail 노드는 포팅하지 않음. 진행 중 collidable
     해제/복구는 Lua(updateTracerWallClimb)가 담당. -->
<animNode>
	<m_Name>TRClimbWallSuccess</m_Name>
	<m_AnimName>TR_ClimbWall_Success</m_AnimName>
	<m_deferredBoneAxis>Y</m_deferredBoneAxis>
	<m_Looped>false</m_Looped>
	<m_SpeedScale>1.04</m_SpeedScale>
	<m_BlendTime>0.10</m_BlendTime>
	<m_Conditions>
		<m_Name>hitreaction</m_Name>
		<m_Type>STRING</m_Type>
		<m_StringValue>TRClimbWallReactionSuccess</m_StringValue>
	</m_Conditions>
	<m_Conditions>
		<m_Name>TRClimbWallStarted</m_Name>
		<m_Type>BOOL</m_Type>
		<m_BoolValue>true</m_BoolValue>
	</m_Conditions>
	<m_Events>
		<m_EventName>SetVariable</m_EventName>
		<m_Time>End</m_Time>
		<m_ParameterValue>TRClimbWallStarted=false</m_ParameterValue>
	</m_Events>
	<m_Events>
		<m_EventName>PlaySound</m_EventName>
		<m_TimePc>0.35</m_TimePc>
		<m_ParameterValue>LandHeavy</m_ParameterValue>
	</m_Events>
</animNode>
