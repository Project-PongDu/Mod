<?xml version="1.0" encoding="utf-8"?>
<!-- 트레이서 벽 클라임 성공 전반부(지상, 0~30%). 텔레포트 신호(TRWallUpDone)는 원본 ClimbWall의
     ClimbWallSuccessDone과 동일하게 TimePc 0.30에 발화 - 애님 30% 지점에
     올라가고 나머지 70%는 위층에서 재생되어 연속적으로 보인다. 이 신호는
     OnZombieUpdate가 아니라 OnTick 감시 큐가 실시간으로 잡는다
     (hitreaction 상태 중 OnZombieUpdate 미발화 때문). 같은 0.30 지점에
     TRWallUpTop=true가 이 노드의 조건(Top==false)을 깨고 후반부 노드
     TRWallUpTop(볼트 애님, 위층 재생)으로 전환한다. End의 Started=false는
     0.30 전환이 실패했을 때의 탈출 폴백. -->
<animNode>
	<m_Name>TRWallUpSuccess</m_Name>
	<m_AnimName>TR_ClimbWall_Success</m_AnimName>
	<m_deferredBoneAxis>Y</m_deferredBoneAxis>
	<m_Looped>false</m_Looped>
	<m_SpeedScale>1.04</m_SpeedScale>
	<m_BlendTime>0.10</m_BlendTime>
	<m_Conditions>
		<m_Name>hitreaction</m_Name>
		<m_Type>STRING</m_Type>
		<m_StringValue>TRWallUpReactionSuccess</m_StringValue>
	</m_Conditions>
	<m_Conditions>
		<m_Name>TRWallUpStarted</m_Name>
		<m_Type>BOOL</m_Type>
		<m_BoolValue>true</m_BoolValue>
	</m_Conditions>
	<m_Conditions>
		<m_Name>TRWallUpTop</m_Name>
		<m_Type>BOOL</m_Type>
		<m_BoolValue>false</m_BoolValue>
	</m_Conditions>
	<m_Events>
		<m_EventName>SetVariable</m_EventName>
		<m_Time>End</m_Time>
		<m_ParameterValue>TRWallUpStarted=false</m_ParameterValue>
	</m_Events>
	<m_Events>
		<m_EventName>SetVariable</m_EventName>
		<m_TimePc>0.30</m_TimePc>
		<m_ParameterValue>TRWallUpDone=true</m_ParameterValue>
	</m_Events>
	<m_Events>
		<m_EventName>SetVariable</m_EventName>
		<m_TimePc>0.30</m_TimePc>
		<m_ParameterValue>TRWallUpTop=true</m_ParameterValue>
	</m_Events>
	<m_Events>
		<m_EventName>PlaySound</m_EventName>
		<m_TimePc>0.35</m_TimePc>
		<m_ParameterValue>LandHeavy</m_ParameterValue>
	</m_Events>
</animNode>
