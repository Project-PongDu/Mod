# Auto detect text files and perform LF normalization
* text=auto

# PZ translation files: on-disk UTF-16 BE + BOM + CRLF (required by the game),
# stored internally as UTF-8 so git can produce readable diffs.
Contents/mods/**/media/lua/shared/Translate/**/*.txt working-tree-encoding=UTF-16 eol=CRLF diff
